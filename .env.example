# LLM
# zmień DAEMON_LLM_MODEL aby przełączyć model bez dotykania kodu
# dostępne modele: ollama list
DAEMON_LLM_MODEL=huihui_ai/qwen3.5-abliterated:9b
DAEMON_OLLAMA_URL=http://localhost:11434

# STT / TTS
DAEMON_LANGUAGE=pl
DAEMON_WHISPER_MODEL=large-v3

# Serwer API
# 0.0.0.0 = dostępny w sieci LAN, 127.0.0.1 = tylko lokalnie
DAEMON_API_HOST=0.0.0.0
DAEMON_API_PORT=8000

# Tryb debugowania — true włącza logi DEBUG we wszystkich modułach
DAEMON_DEBUG_MODE=false

# Wake Word — Picovoice Porcupine
# AccessKey z: https://console.picovoice.ai/
DAEMON_PORCUPINE_ACCESS_KEY=
